@startuml STLA_Full_Project_Architecture
title STLA Desktop — Full Project Architecture
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

' ========== UI ==========
package "UI" {
  package "com.stla.ui.auth" {
    class LoginController
    class RegisterController
  }
  package "com.stla.ui.student" {
    class StudentDashboardController
    class CourseCatalogController
    class CheckoutController
    class StudentCoursePlayerController
    class CourseDetailsController
    class MyCoursesController
    class QuizTakeController
    class CertificatesController
  }
  package "com.stla.ui.instructor" {
    class InstructorDashboardController
    class AddCourseController
    class CoursePlayerController
    class InstructorCoursesController
    class WalletController
    class QuizBuilderController
  }
  package "com.stla.ui.admin" {
    class AdminDashboardController
    class CourseReviewController
    class CourseReviewDetailController
    class UsersManagementController
    class CoursesManagementController
    class InstructorVerificationController
  }
  package "com.stla.ui.components" {
    class ComponentFactory
    class CourseCardFactory
    class ChartFactory
  }
}

' ========== Services ==========
package "Services" {
  class AuthService
  class CourseService
  class CourseDetailsService
  class PaymentService
  class EnrollmentService
  class LessonService
  class QuizService
  class NotificationService
  class WalletService
  class DashboardService
  class ProfileService
  class LearningProgressService
  class CertificateService
  class AdminService
  class InstructorService
  class ReviewService
  class SupabaseStorageAdapter
}

' ========== Repository interfaces ==========
package "Repositories (interfaces)" {
  interface CourseRepository
  interface ProfileRepository
  interface StudentRepository
  interface InstructorRepository
  interface AdminRepository
  interface CategoryRepository
  interface NotificationRepository
}

' ========== Repository implementations ==========
package "Repositories (implementations)" {
  class CourseRepositoryImpl
  class ProfileRepositoryImpl
  class StudentRepositoryImpl
  class InstructorRepositoryImpl
  class AdminRepositoryImpl
  class CategoryRepositoryImpl
  class NotificationRepositoryImpl
  class EnrollmentRepository
  class PaymentRepository
  class WalletRepository
  class SectionRepositoryImpl
  class LessonRepositoryImpl
  class QuizRepositoryImpl
  class ResourceRepositoryImpl
}

' ========== Domain ==========
package "Domain Models" {
  class Profile
  class Student
  class Instructor
  class Admin
  class Course
  class CourseSection
  class CourseLesson
  class LessonResource
  class Category
  class Enrollment
  class Payment
  class Quiz
  class QuizQuestion
  class QuizOption
  class Notification
}

' ========== Patterns ==========
package "Patterns" {
  package "Factory" {
    class UserFactory
    class PaymentStrategyFactory
    class ComponentFactory <<UI>>
  }
  package "Strategy" {
    interface PaymentStrategy
    class VisaPaymentStrategy
    interface WithdrawStrategy
  }
  package "Observer" {
    class EventBus
    interface EventListener
    class NotificationObserver
    record AppEvent
  }
  package "Facade" {
    class EnrollmentFacade
    class CoursePublishFacade
  }
  package "Decorator" {
    interface CourseComponent
    class BaseCourse
    abstract class CourseDecorator
  }
  package "Proxy" {
    class CourseAccessProxy
    class AccessControlProxy
  }
  package "Singleton" {
    class AppConfig
    class DatabaseConnection
    class SessionManager
    class ThemeManager
  }
  package "Adapter" {
    interface PaymentGatewayAdapter
    class SupabaseStorageAdapter <<services>>
  }
}

' ========== Core ==========
package "Core" {
  class AppConfig
  class DatabaseConnection
  class SessionManager
  class NavigationManager
  class StlaApplication
  class ResultSetMapper
}

' ========== Architecture flow ==========
CheckoutController --> CourseDetailsService
CheckoutController --> EnrollmentFacade
StudentDashboardController --> CourseService
AddCourseController --> CoursePublishFacade
AdminDashboardController --> DashboardService
LoginController --> AuthService

CourseService --> CourseRepositoryImpl
PaymentService --> PaymentRepository
PaymentService --> EnrollmentRepository
LessonService --> SectionRepositoryImpl
NotificationService --> NotificationRepositoryImpl
AuthService --> ProfileRepositoryImpl

CourseRepository <|.. CourseRepositoryImpl
ProfileRepository <|.. ProfileRepositoryImpl
StudentRepository <|.. StudentRepositoryImpl
InstructorRepository <|.. InstructorRepositoryImpl
AdminRepository <|.. AdminRepositoryImpl
CategoryRepository <|.. CategoryRepositoryImpl
NotificationRepository <|.. NotificationRepositoryImpl

CourseRepositoryImpl --> DatabaseConnection
EnrollmentRepository --> DatabaseConnection
PaymentRepository --> DatabaseConnection
ProfileRepositoryImpl --> DatabaseConnection

CourseService --> Course
PaymentService --> Payment
EnrollmentService --> Enrollment
LessonService --> CourseLesson

NavigationManager ..> LoginController : navigateTo
NavigationManager ..> StudentDashboardController : navigateToDashboard
SessionManager --> Profile
SessionManager --> Student
SessionManager --> Instructor
SessionManager --> Admin

DatabaseConnection ..> AppConfig
EnrollmentFacade --> PaymentService
CoursePublishFacade --> CourseRepositoryImpl
CoursePublishFacade --> NotificationService

StudentCoursePlayerController --> CourseAccessProxy
CourseAccessProxy --> EnrollmentService

AuthService ..> UserFactory
CheckoutController ..> PaymentStrategyFactory

EventBus o-- EventListener
NotificationObserver ..> EventBus

note bottom of EnrollmentRepository
  EnrollmentRepository, PaymentRepository, WalletRepository
  have no domain.interfaces counterpart.
end note

@enduml
