@startuml STLA_Factory_Pattern
title STLA Desktop — Factory Pattern
skinparam classAttributeIconSize 0

package "com.stla.patterns.factory" {
  class UserFactory {
    + {static} createRoleRecord(role, profile): Object
    + {static} createStudent(profile): Student
    + {static} createInstructor(profile): Instructor
    + {static} createAdmin(profile): Admin
  }

  note bottom of UserFactory
    StudentFactory, InstructorFactory, AdminFactory
    **not found in current codebase**.
    Role creation is centralized in UserFactory.
  end note
}

package "com.stla.patterns.strategy" {
  class PaymentStrategyFactory {
    + {static} visa(...): PaymentStrategy
    + {static} digitalWallet(...): PaymentStrategy
  }
  class WithdrawStrategyFactory {
    + {static} getStrategy(method): WithdrawStrategy
    + {static} getAll(): Map
  }
}

package "com.stla.ui.components" {
  class ComponentFactory {
    + {static} createStatCard(...)
    + {static} createStatusBadge(...)
    + {static} createLoadingState()
    + {static} createEmptyState(...)
    + {static} showConfirmDialog(...)
  }
  class CourseCardFactory {
    + {static} createCard(...)
  }
  class ChartFactory {
    + {static} createBarChart(...)
    + {static} createAreaChart(...)
    + {static} createPieChart(...)
  }
}

package "com.stla.domain.models" {
  class Student
  class Instructor
  class Admin
  class Profile
}

package "com.stla.patterns.strategy.products" {
  interface PaymentStrategy
  class VisaPaymentStrategy
  class WalletPaymentStrategy
  class VisaWithdrawStrategy
  class DigitalWalletWithdrawStrategy
}

package "com.stla.services" {
  class AuthService
}

package "com.stla.ui.student" {
  class CheckoutController
}

package "com.stla.ui.instructor" {
  class InstructorWithdrawController
}

UserFactory ..> Student : creates
UserFactory ..> Instructor : creates
UserFactory ..> Admin : creates
AuthService ..> UserFactory

PaymentStrategyFactory ..> VisaPaymentStrategy
PaymentStrategyFactory ..> WalletPaymentStrategy
WithdrawStrategyFactory ..> VisaWithdrawStrategy
WithdrawStrategyFactory ..> DigitalWalletWithdrawStrategy

CheckoutController ..> PaymentStrategyFactory
InstructorWithdrawController ..> WithdrawStrategyFactory

package "com.stla.ui.student" {
  class StudentDashboardController
}

StudentDashboardController ..> ComponentFactory
StudentDashboardController ..> CourseCardFactory

@enduml
