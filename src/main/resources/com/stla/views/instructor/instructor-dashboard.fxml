<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.stla.ui.instructor.InstructorDashboardController"
            fx:id="rootPane" prefWidth="1400" prefHeight="900">
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <VBox styleClass="sidebar-header" spacing="4">
                <Label text="📚 STLA" styleClass="sidebar-logo"/>
                <Label text="Instructor Portal" styleClass="sidebar-subtitle"/>
            </VBox>
            <Region styleClass="sidebar-separator"/>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="2" style="-fx-padding: 8 0;">
                    <Label text="MAIN" styleClass="sidebar-section-title"/>
                    <Button text="🏠  Dashboard" styleClass="sidebar-item, sidebar-item-active" onAction="#handleNavDashboard"/>
                    <Button text="📚  My Courses" styleClass="sidebar-item" onAction="#handleNavCourses"/>
                    <Button text="➕  Create Course" styleClass="sidebar-item" onAction="#handleNavAddCourse"/>
                    <Label text="MANAGEMENT" styleClass="sidebar-section-title"/>
                    <Button text="👥  Students" styleClass="sidebar-item" onAction="#handleNavStudents"/>
                    <Label text="FINANCE" styleClass="sidebar-section-title"/>
                    <Button text="💰  Wallet" styleClass="sidebar-item" onAction="#handleNavWallet"/>
                    <Button text="💸  Withdraw" styleClass="sidebar-item" onAction="#handleNavWithdraw"/>
                    <Label text="ACCOUNT" styleClass="sidebar-section-title"/>
                    <Button text="🔔  Notifications" styleClass="sidebar-item" onAction="#handleNavNotifications"/>
                    <Button text="👤  Profile" styleClass="sidebar-item" onAction="#handleNavProfile"/>
                </VBox>
            </ScrollPane>
            <VBox styleClass="sidebar-user" spacing="4">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane fx:id="sidebarAvatarContainer" prefWidth="36" prefHeight="36"/>
                    <VBox spacing="2">
                        <Label fx:id="userNameLabel" text="Instructor" styleClass="sidebar-user-name"/>
                        <Label text="INSTRUCTOR" styleClass="sidebar-user-role"/>
                    </VBox>
                </HBox>
                <Region prefHeight="6"/>
                <Button text="🚪  Sign Out" styleClass="sidebar-item" style="-fx-text-fill: #EF6B6B;" onAction="#handleLogout"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <VBox spacing="0">
            <HBox styleClass="top-header" alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="pageTitle" text="Instructor Dashboard" styleClass="page-title"/>
                    <Label fx:id="welcomeLabel" text="Manage your courses and earnings" styleClass="page-subtitle"/>
                </VBox>
                <StackPane fx:id="notificationBellHost" prefWidth="40" prefHeight="40"/>
                <StackPane fx:id="headerAvatarContainer" prefWidth="36" prefHeight="36"/>
            </HBox>
            <ScrollPane fx:id="contentScroll" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox fx:id="contentArea" styleClass="content-area" spacing="24">
                    <HBox fx:id="statsRow" spacing="20"/>
                    <VBox spacing="12">
                        <Label text="My Courses" styleClass="section-title"/>
                        <VBox fx:id="coursesBox" spacing="12"><Label text="Loading courses..." styleClass="text-secondary"/></VBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
