<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.stla.ui.instructor.InstructorProfileController"
            fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent;">
    <VBox spacing="20" style="-fx-padding: 28 32; -fx-background-color: #0a0f1e;">

        <!-- Verification Status Card -->
        <VBox fx:id="verificationCard" spacing="8" styleClass="card" style="-fx-padding: 16 20;">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="verifyIcon" text="⏳" style="-fx-font-size: 28px;"/>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="verifyTitle" text="Verification Status" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                    <Label fx:id="verifyMessage" text="Your documents are under review." style="-fx-font-size: 13px; -fx-text-fill: #8899b4;" wrapText="true"/>
                </VBox>
                <Label fx:id="verifyBadge" text="PENDING" styleClass="badge, badge-warning"/>
            </HBox>
            <Label fx:id="rejectionLabel" text="" style="-fx-text-fill: #EF4444; -fx-font-size: 12px;" wrapText="true" managed="false" visible="false"/>
        </VBox>

        <!-- Profile Header -->
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 20;">
            <StackPane fx:id="avatarContainer" prefWidth="80" prefHeight="80"/>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="nameLabel" text="Instructor Name" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label fx:id="emailLabel" text="—" style="-fx-font-size: 14px; -fx-text-fill: #8899b4;"/>
                <Label fx:id="memberSinceLabel" text="Member since 2024" style="-fx-font-size: 12px; -fx-text-fill: #4a6080;"/>
            </VBox>
            <Button text="📷 Change Avatar" styleClass="btn-outline, btn-sm" onAction="#handleAvatarChange"/>
        </HBox>

        <!-- Stats Row -->
        <HBox fx:id="statsRow" spacing="16"/>

        <!-- Personal Info Section -->
        <VBox spacing="10" styleClass="card" style="-fx-padding: 20;">
            <Label text="📋 Personal Information" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="FULL NAME" styleClass="form-label"/>
                    <TextField fx:id="editNameField" prefHeight="36"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="PHONE" styleClass="form-label"/>
                    <TextField fx:id="editPhoneField" prefHeight="36"/>
                </VBox>
            </HBox>
            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="COUNTRY" styleClass="form-label"/>
                    <TextField fx:id="editCountryField" prefHeight="36"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="BIO" styleClass="form-label"/>
                    <TextArea fx:id="editBioField" prefHeight="60" wrapText="true"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Instructor Info Section -->
        <VBox spacing="10" styleClass="card" style="-fx-padding: 20;">
            <Label text="👨‍🏫 Instructor Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="PROFESSIONAL TITLE" styleClass="form-label"/>
                    <TextField fx:id="editTitleField" prefHeight="36"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="YEARS EXPERIENCE" styleClass="form-label"/>
                    <TextField fx:id="editYearsField" prefHeight="36"/>
                </VBox>
            </HBox>
            <VBox spacing="4">
                <Label text="EXPERTISE TAGS" styleClass="form-label"/>
                <TextField fx:id="editExpertiseField" promptText="Comma separated" prefHeight="36"/>
            </VBox>
            <VBox spacing="4">
                <Label text="INSTRUCTOR BIO" styleClass="form-label"/>
                <TextArea fx:id="editInstructorBioField" prefHeight="60" wrapText="true"/>
            </VBox>
        </VBox>

        <!-- Verification Documents Section -->
        <VBox spacing="10" styleClass="card" style="-fx-padding: 20;">
            <Label text="📄 Verification Documents" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <HBox spacing="12">
                <VBox fx:id="docIdFrontStatus" spacing="4" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Label text="ID Front"/>
                    <Label fx:id="docIdFrontLabel" text="❌ Not uploaded" style="-fx-font-size: 11px;"/>
                </VBox>
                <VBox fx:id="docIdBackStatus" spacing="4" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Label text="ID Back"/>
                    <Label fx:id="docIdBackLabel" text="❌ Not uploaded" style="-fx-font-size: 11px;"/>
                </VBox>
                <VBox fx:id="docCertStatus" spacing="4" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Label text="Certificate"/>
                    <Label fx:id="docCertLabel" text="❌ Not uploaded" style="-fx-font-size: 11px;"/>
                </VBox>
                <VBox fx:id="docCvStatus" spacing="4" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Label text="CV / Resume"/>
                    <Label fx:id="docCvLabel" text="❌ Not uploaded" style="-fx-font-size: 11px;"/>
                </VBox>
            </HBox>
            <Button fx:id="resubmitBtn" text="📤 Resubmit Documents" styleClass="btn-outline" onAction="#handleResubmitDocuments" managed="false" visible="false"/>
        </VBox>

        <!-- Action Buttons -->
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Cancel" styleClass="btn-outline" onAction="#handleCancel" prefHeight="40" prefWidth="120"/>
            <Button fx:id="saveBtn" text="💾 Save Changes" styleClass="btn-gradient" onAction="#handleSave" prefHeight="40" prefWidth="200"/>
        </HBox>
        <ProgressIndicator fx:id="saveLoading" prefWidth="24" prefHeight="24" managed="false" visible="false"/>
    </VBox>
</ScrollPane>
