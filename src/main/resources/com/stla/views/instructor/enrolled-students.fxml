<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.stla.ui.instructor.EnrolledStudentsController"
      spacing="16" style="-fx-padding: 28 32; -fx-background-color: #0a0f1e;">
    <Label text="👥 Enrolled Students" styleClass="heading-1"/>
    <Label text="All students across your courses" styleClass="subtitle"/>
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <VBox fx:id="studentsContainer" spacing="4"/>
    </ScrollPane>
</VBox>
