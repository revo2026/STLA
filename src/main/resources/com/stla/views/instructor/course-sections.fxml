<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.stla.ui.instructor.CourseSectionsController"
      spacing="16" styleClass="content-area">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <!-- Course Header -->
    <HBox fx:id="courseHeader" spacing="16" alignment="CENTER_LEFT">
        <VBox HBox.hgrow="ALWAYS">
            <Label fx:id="courseTitle" text="Course" styleClass="page-title"/>
            <Label fx:id="courseStatus" text="" styleClass="text-secondary"/>
        </VBox>
        <Button fx:id="btnAddSection" text="➕ Add Section" styleClass="btn-primary" onAction="#handleAddSection"/>
        <Button fx:id="btnAddQuiz" text="📝 Add Quiz" styleClass="btn-outline" onAction="#handleAddQuiz"/>
    </HBox>

    <!-- Sections List -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <VBox fx:id="sectionsContainer" spacing="16"/>
    </ScrollPane>
</VBox>
