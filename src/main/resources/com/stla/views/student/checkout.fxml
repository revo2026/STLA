<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.stla.ui.student.CheckoutController"
           style="-fx-background-color: #0a0f1e;">

    <Region maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308" mouseTransparent="true"
            style="-fx-background-color: radial-gradient(center 15% 20%, radius 45%, rgba(45,212,191,0.14), transparent 65%);"/>
    <Region maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308" mouseTransparent="true"
            style="-fx-background-color: radial-gradient(center 85% 80%, radius 40%, rgba(14,165,233,0.12), transparent 60%);"/>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
        <VBox fx:id="rootBox" spacing="28" maxWidth="1040" style="-fx-padding: 28 24 40 24; -fx-background-color: transparent;">

            <VBox spacing="8">
                <Label text="Secure Payment" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                <Label text="Choose your preferred payment method" style="-fx-font-size: 14px; -fx-text-fill: #8899b4;"/>
            </VBox>

            <FlowPane hgap="24" vgap="24" prefWrapLength="920" style="-fx-padding: 0;">

                <VBox spacing="20" minWidth="300" prefWidth="580" style="-fx-background-color: transparent;">
                    <VBox spacing="16" styleClass="checkout-card">
                        <Label text="Payment method" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>

                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <VBox fx:id="visaMethodCard" styleClass="payment-method-card" onMouseClicked="#selectVisa" spacing="8" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308">
                                <Label text="💳" style="-fx-font-size: 32px;"/>
                                <Label text="Visa / MasterCard" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                                <Label text="Pay with debit or credit card" wrapText="true" maxWidth="260"
                                       style="-fx-font-size: 12px; -fx-text-fill: #8899b4;"/>
                            </VBox>
                            <VBox fx:id="walletMethodCard" styleClass="payment-method-card" onMouseClicked="#selectWallet" spacing="8" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308">
                                <Label text="👛" style="-fx-font-size: 32px;"/>
                                <Label text="Wallet" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                                <Label text="Mobile wallet &amp; instant transfer" wrapText="true" maxWidth="260"
                                       style="-fx-font-size: 12px; -fx-text-fill: #8899b4;"/>
                            </VBox>
                        </HBox>

                        <VBox fx:id="visaForm" spacing="14">
                            <VBox styleClass="visa-card-preview" spacing="10">
                                <Label fx:id="cardPreviewNumber" text="**** **** **** ****"
                                       style="-fx-text-fill: #f0f6ff; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                                <Label fx:id="cardPreviewName" text="CARDHOLDER NAME"
                                       style="-fx-text-fill: rgba(240,246,255,0.75); -fx-font-size: 12px; -fx-letter-spacing: 2;"/>
                            </VBox>

                            <Label text="Cardholder Name" style="-fx-font-family: Consolas; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 1.5;"/>
                            <TextField fx:id="cardholderField" promptText="Full name on card" maxWidth="1.7976931348623157E308" prefHeight="46"
                                       style="-fx-background-color: rgba(255,255,255,0.08); -fx-border-color: rgba(255,255,255,0.14); -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #f0f6ff; -fx-prompt-text-fill: #4a6080; -fx-padding: 0 16 0 16;"/>

                            <Label text="Card Number" style="-fx-font-family: Consolas; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 1.5;"/>
                            <TextField fx:id="cardNumberField" promptText="0000 0000 0000 0000" maxWidth="1.7976931348623157E308" prefHeight="46"
                                       style="-fx-background-color: rgba(255,255,255,0.08); -fx-border-color: rgba(255,255,255,0.14); -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #f0f6ff; -fx-prompt-text-fill: #4a6080; -fx-padding: 0 16 0 16;"/>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="Expiry (MM/YY)" style="-fx-font-family: Consolas; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 1.5;"/>
                                    <TextField fx:id="expiryField" promptText="MM/YY" prefHeight="46" maxWidth="1.7976931348623157E308"
                                               style="-fx-background-color: rgba(255,255,255,0.08); -fx-border-color: rgba(255,255,255,0.14); -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #f0f6ff; -fx-prompt-text-fill: #4a6080; -fx-padding: 0 16 0 16;"/>
                                </VBox>
                                <VBox spacing="6" prefWidth="140" minWidth="120">
                                    <Label text="CVV" style="-fx-font-family: Consolas; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 1.5;"/>
                                    <TextField fx:id="cvvField" promptText="CVV" prefHeight="46" maxWidth="1.7976931348623157E308"
                                               style="-fx-background-color: rgba(255,255,255,0.08); -fx-border-color: rgba(255,255,255,0.14); -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #f0f6ff; -fx-prompt-text-fill: #4a6080; -fx-padding: 0 16 0 16;"/>
                                </VBox>
                            </HBox>

                            <Label text="🔒 Your payment information is encrypted and secure."
                                   wrapText="true" maxWidth="520"
                                   style="-fx-font-size: 12px; -fx-text-fill: #8899b4;"/>
                        </VBox>

                        <VBox fx:id="walletForm" spacing="14" visible="false">
                            <Label text="Wallet Provider" style="-fx-font-family: Consolas; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 1.5;"/>
                            <ComboBox fx:id="walletProviderCombo" maxWidth="1.7976931348623157E308" prefHeight="46"
                                      style="-fx-background-color: rgba(255,255,255,0.08); -fx-border-color: rgba(255,255,255,0.14); -fx-border-radius: 12; -fx-background-radius: 12;"/>

                            <Label text="Mobile Number" style="-fx-font-family: Consolas; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 1.5;"/>
                            <TextField fx:id="walletIdentifierField" promptText="Wallet number or email" prefHeight="46" maxWidth="1.7976931348623157E308"
                                       style="-fx-background-color: rgba(255,255,255,0.08); -fx-border-color: rgba(255,255,255,0.14); -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #f0f6ff; -fx-prompt-text-fill: #4a6080; -fx-padding: 0 16 0 16;"/>

                            <Label text="You will receive a confirmation code on your mobile."
                                   wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #8899b4;"/>
                        </VBox>

                        <Label fx:id="errorLabel" styleClass="payment-error-label" wrapText="true" maxWidth="1.7976931348623157E308"/>
                    </VBox>

                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button text="Cancel" onAction="#handleCancel" prefHeight="44" minWidth="120"
                                style="-fx-background-color: rgba(255,255,255,0.06); -fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #8899b4; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button fx:id="payButton" text="Pay Securely" onAction="#handlePay" prefHeight="50" minWidth="220"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: linear-gradient(to right, #2dd4bf, #0ea5e9); -fx-text-fill: #061018; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 13; -fx-border-radius: 13; -fx-cursor: hand; -fx-padding: 12 28; -fx-effect: dropshadow(gaussian, rgba(45,212,191,0.40), 20, 0.15, 0, 4);"/>
                    </HBox>
                </VBox>

                <VBox spacing="16" minWidth="280" prefWidth="340" maxWidth="400" styleClass="checkout-card">
                    <Label text="Order summary" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>

                    <Separator style="-fx-background-color: rgba(255,255,255,0.08);"/>

                    <VBox spacing="4">
                        <Label text="Item" style="-fx-font-size: 11px; -fx-text-fill: #4a6080; -fx-font-weight: bold;"/>
                        <Label fx:id="courseTitleLabel" wrapText="true" maxWidth="360"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                        <Label fx:id="instructorLabel" wrapText="true" maxWidth="360"
                               style="-fx-font-size: 13px; -fx-text-fill: #8899b4;"/>
                    </VBox>

                    <VBox spacing="10">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Subtotal" style="-fx-text-fill: #8899b4; -fx-font-size: 13px;" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="originalPriceLabel" style="-fx-text-fill: #f0f6ff; -fx-font-size: 13px;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Service fee" style="-fx-text-fill: #8899b4; -fx-font-size: 13px;" HBox.hgrow="ALWAYS"/>
                            <Label text="\$0.00" style="-fx-text-fill: #f0f6ff; -fx-font-size: 13px;"/>
                        </HBox>
                        <Separator style="-fx-background-color: rgba(255,255,255,0.08);"/>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Total" style="-fx-text-fill: #f0f6ff; -fx-font-size: 14px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="finalPriceLabel" styleClass="checkout-price"/>
                        </HBox>
                    </VBox>
                </VBox>
            </FlowPane>

            <HBox spacing="24" alignment="CENTER_LEFT" style="-fx-padding: 8 0 0 0;">
                <Label text="Powered by Supabase" style="-fx-font-size: 12px; -fx-text-fill: #4a6080;"/>
                <Label text="•" style="-fx-font-size: 12px; -fx-text-fill: #4a6080;"/>
                <Label text="256-bit SSL Secure Payment" style="-fx-font-size: 12px; -fx-text-fill: #4a6080;"/>
            </HBox>
        </VBox>
    </ScrollPane>

    <VBox fx:id="loadingOverlay" styleClass="payment-loading-overlay" visible="false" managed="false" spacing="12"
          maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
        <ProgressIndicator prefWidth="48" prefHeight="48" style="-fx-progress-color: #2dd4bf;"/>
        <Label text="Processing payment..." style="-fx-text-fill: #f0f6ff; -fx-font-size: 14px;"/>
    </VBox>
</StackPane>
