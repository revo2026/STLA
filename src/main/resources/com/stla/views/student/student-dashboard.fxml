<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.stla.ui.student.StudentDashboardController"
            fx:id="rootPane" prefWidth="1400" prefHeight="900"
            style="-fx-background-color: #0a0f1e;">
    <left>
        <VBox prefWidth="288" minWidth="280" maxWidth="300" spacing="0"
              style="-fx-background-color: rgba(10,15,30,0.92); -fx-border-color: transparent rgba(255,255,255,0.12) transparent transparent; -fx-border-width: 0 1 0 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.38), 48, 0.10, 0, 16);">
            <VBox styleClass="sidebar-header" spacing="6"
                  style="-fx-padding: 28 22 20 22; -fx-background-color: transparent;">
                <Label text="📚 STLA"
                       style="-fx-font-family: 'Georgia', 'Times New Roman', serif; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                <Label text="Student Portal"
                       style="-fx-font-family: 'Segoe UI', sans-serif; -fx-font-size: 11px; -fx-text-fill: #4a6080; -fx-letter-spacing: 0.5;"/>
            </VBox>
            <Region prefHeight="1" maxHeight="1" minHeight="1"
                    style="-fx-background-color: rgba(255,255,255,0.08);"/>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="4" style="-fx-padding: 12 14 16 14;">
                    <Label text="MAIN"
                           style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 1.2; -fx-padding: 8 8 6 8;"/>
                    <Button fx:id="navDashboard" text="🏠  Dashboard" styleClass="sidebar-item, sidebar-item-active" onAction="#handleNavDashboard"
                            maxWidth="1.7976931348623157E308" style="-fx-min-height: 46; -fx-pref-height: 48;"/>
                    <Button text="📖  Course Catalog" styleClass="sidebar-item" onAction="#handleNavCatalog"
                            maxWidth="1.7976931348623157E308" style="-fx-min-height: 46; -fx-pref-height: 48;"/>
                    <Button text="📚  My Courses" styleClass="sidebar-item" onAction="#handleNavMyCourses"
                            maxWidth="1.7976931348623157E308" style="-fx-min-height: 46; -fx-pref-height: 48;"/>
                    <Label text="LEARNING"
                           style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 1.2; -fx-padding: 16 8 6 8;"/>
                    <Button text="🎯  Quizzes" styleClass="sidebar-item" onAction="#handleNavQuizzes"
                            maxWidth="1.7976931348623157E308" style="-fx-min-height: 46; -fx-pref-height: 48;"/>
                    <Button text="🏆  Certificates" styleClass="sidebar-item" onAction="#handleNavCertificates"
                            maxWidth="1.7976931348623157E308" style="-fx-min-height: 46; -fx-pref-height: 48;"/>
                    <Label text="ACCOUNT"
                           style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 1.2; -fx-padding: 16 8 6 8;"/>
                    <Button text="⭐  My Reviews" styleClass="sidebar-item" onAction="#handleNavReviews"
                            maxWidth="1.7976931348623157E308" style="-fx-min-height: 46; -fx-pref-height: 48;"/>
                    <Button text="👤  Profile" styleClass="sidebar-item" onAction="#handleNavProfile"
                            maxWidth="1.7976931348623157E308" style="-fx-min-height: 46; -fx-pref-height: 48;"/>
                    <Button text="🔔  Notifications" styleClass="sidebar-item" onAction="#handleNavNotifications"
                            maxWidth="1.7976931348623157E308" style="-fx-min-height: 46; -fx-pref-height: 48;"/>
                </VBox>
            </ScrollPane>
            <VBox style="-fx-padding: 18 20 22 20; -fx-background-color: rgba(0,0,0,0.22);" spacing="6">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane fx:id="sidebarAvatarContainer" prefWidth="40" prefHeight="40"
                               style="-fx-background-radius: 999; -fx-border-radius: 999; -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1;"/>
                    <VBox spacing="2">
                        <Label fx:id="userNameLabel" text="Student Name"
                               style="-fx-font-family: 'Segoe UI', sans-serif; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                        <Label text="STUDENT"
                               style="-fx-font-family: 'Segoe UI', sans-serif; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #2dd4bf; -fx-letter-spacing: 0.8;"/>
                    </VBox>
                </HBox>
                <Region prefHeight="4" minHeight="4"/>
                <Button text="🚪  Sign Out" styleClass="sidebar-item" onAction="#handleLogout"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-font-family: 'Segoe UI', sans-serif; -fx-text-fill: #ef4444; -fx-min-height: 44;"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <StackPane style="-fx-background-color: #0a0f1e;">
            <Region mouseTransparent="true" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308"
                    style="-fx-background-color: radial-gradient(center 25% 20%, radius 45%, rgba(45,212,191,0.10), transparent 60%);"/>
            <Region mouseTransparent="true" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308"
                    style="-fx-background-color: radial-gradient(center 80% 75%, radius 40%, rgba(14,165,233,0.10), transparent 58%);"/>
            <VBox spacing="0" maxWidth="1.7976931348623157E308" maxHeight="1.7976931348623157E308">
                <HBox alignment="CENTER_LEFT" spacing="20"
                      style="-fx-background-color: rgba(255,255,255,0.04); -fx-border-color: transparent transparent rgba(255,255,255,0.12) transparent; -fx-border-width: 0 0 1 0; -fx-padding: 28 32 28 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 16, 0.08, 0, 4);">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="pageTitle" text="Dashboard"
                               style="-fx-font-family: 'Georgia', 'Times New Roman', serif; -fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                        <Label fx:id="welcomeLabel" text="Welcome back!"
                               style="-fx-font-family: 'Segoe UI', sans-serif; -fx-font-size: 14px; -fx-text-fill: #8899b4;"/>
                    </VBox>
                    <Button text="🔔" styleClass="notification-bell"
                            prefWidth="44" prefHeight="44" minWidth="44" minHeight="44"
                            style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 999; -fx-text-fill: #f0f6ff; -fx-font-size: 18px; -fx-cursor: hand; -fx-padding: 0; -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 8, 0, 0, 2);"/>
                    <StackPane fx:id="headerAvatarContainer" prefWidth="40" prefHeight="40"
                               style="-fx-background-radius: 999; -fx-border-radius: 999; -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1; -fx-cursor: hand;"/>
                </HBox>
                <ScrollPane fx:id="contentScroll" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
                    <VBox fx:id="contentArea" spacing="28"
                          style="-fx-padding: 32 40 44 40; -fx-background-color: transparent;">
                        <!-- Stats: glass section (stat cards from code keep their own chrome) -->
                        <VBox spacing="16"
                              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 20; -fx-border-width: 1; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.38), 48, 0.10, 0, 16);">
                            <HBox fx:id="statsRow" spacing="20" alignment="CENTER_LEFT"/>
                        </VBox>
                        <VBox spacing="14"
                              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 20; -fx-border-width: 1; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.38), 48, 0.10, 0, 16);">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Featured Courses"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-font-family: 'Georgia', serif; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                                <Button text="View All" onAction="#handleNavCatalog"
                                        style="-fx-font-family: 'Segoe UI', sans-serif; -fx-background-color: transparent; -fx-text-fill: #2dd4bf; -fx-font-size: 13px; -fx-font-weight: bold; -fx-underline: true; -fx-cursor: hand; -fx-padding: 4 8;"/>
                            </HBox>
                            <HBox fx:id="featuredCoursesRow" spacing="20" alignment="CENTER_LEFT"/>
                        </VBox>
                        <VBox spacing="14"
                              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 20; -fx-border-width: 1; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.38), 48, 0.10, 0, 16);">
                            <Label text="Continue Learning"
                                   style="-fx-font-family: 'Georgia', serif; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                            <VBox fx:id="continueLearningBox" spacing="12"/>
                        </VBox>
                        <VBox spacing="14"
                              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 20; -fx-border-width: 1; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.38), 48, 0.10, 0, 16);">
                            <Label text="Recent Notifications"
                                   style="-fx-font-family: 'Georgia', serif; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>
                            <VBox fx:id="notificationsBox" spacing="10">
                                <Label text="No new notifications" styleClass="empty-state-message"
                                       style="-fx-font-family: 'Segoe UI', sans-serif; -fx-font-size: 14px; -fx-text-fill: #4a6080;"/>
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
