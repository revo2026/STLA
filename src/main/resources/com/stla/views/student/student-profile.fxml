<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.stla.ui.student.StudentProfileController"
            fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: transparent;">
    <VBox spacing="20" style="-fx-padding: 28 32; -fx-background-color: #0a0f1e;">

        <Label text="👤 My Profile" styleClass="heading-1"/>

        <!-- ======== VIEW MODE ======== -->
        <VBox fx:id="viewPane" styleClass="card" spacing="16" style="-fx-padding: 28;">
            <!-- Avatar + Info Header -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <StackPane fx:id="avatarContainer" prefWidth="80" prefHeight="80"/>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label fx:id="nameLabel" text="" styleClass="heading-2"/>
                    <Label fx:id="emailLabel" text="" styleClass="text-secondary"/>
                    <Label fx:id="roleLabel" text="" styleClass="badge, badge-student"/>
                </VBox>
                <Button fx:id="editBtn" text="✏️  Edit Profile" styleClass="btn-gradient, btn-sm" onAction="#toggleEdit"/>
            </HBox>

            <Separator/>

            <HBox spacing="40">
                <VBox spacing="4"><Label text="HEADLINE" styleClass="form-label"/><Label fx:id="headlineLabel" text="" style="-fx-text-fill: #f0f6ff;"/></VBox>
                <VBox spacing="4"><Label text="COUNTRY" styleClass="form-label"/><Label fx:id="countryLabel" text="" style="-fx-text-fill: #f0f6ff;"/></VBox>
                <VBox spacing="4"><Label text="PHONE" styleClass="form-label"/><Label fx:id="phoneLabel" text="" style="-fx-text-fill: #f0f6ff;"/></VBox>
            </HBox>

            <VBox spacing="4"><Label text="BIO" styleClass="form-label"/><Label fx:id="bioLabel" text="" wrapText="true" style="-fx-text-fill: #f0f6ff;"/></VBox>

            <HBox spacing="40">
                <VBox spacing="4"><Label text="LEARNING GOALS" styleClass="form-label"/><Label fx:id="goalsLabel" text="" wrapText="true" style="-fx-text-fill: #f0f6ff;"/></VBox>
                <VBox spacing="4"><Label text="INTERESTS" styleClass="form-label"/><Label fx:id="interestsLabel" text="" wrapText="true" style="-fx-text-fill: #f0f6ff;"/></VBox>
            </HBox>

            <HBox spacing="40">
                <VBox spacing="4"><Label text="SKILL LEVEL" styleClass="form-label"/><Label fx:id="skillLabel" text="" style="-fx-text-fill: #f0f6ff;"/></VBox>
                <VBox spacing="4"><Label text="PREFERRED LANGUAGE" styleClass="form-label"/><Label fx:id="langLabel" text="" style="-fx-text-fill: #f0f6ff;"/></VBox>
                <VBox spacing="4"><Label text="DAILY GOAL" styleClass="form-label"/><Label fx:id="dailyGoalLabel" text="" style="-fx-text-fill: #f0f6ff;"/></VBox>
            </HBox>
        </VBox>

        <!-- ======== EDIT MODE ======== -->
        <VBox fx:id="editPane" styleClass="card" spacing="14" style="-fx-padding: 28;" managed="false" visible="false">
            <Label text="Edit Profile" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;"/>

            <!-- Avatar Edit -->
            <HBox spacing="16" alignment="CENTER_LEFT">
                <StackPane fx:id="editAvatarContainer" prefWidth="80" prefHeight="80"/>
                <VBox spacing="6">
                    <Button text="📷  Change Photo" styleClass="btn-outline, btn-sm" onAction="#handleChangeAvatar"/>
                    <Label text="PNG, JPG, WEBP — max 5MB" style="-fx-font-size: 10px; -fx-text-fill: #4a6080;"/>
                </VBox>
            </HBox>

            <!-- Fields -->
            <HBox spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="FULL NAME *" styleClass="form-label"/>
                    <TextField fx:id="editNameField" prefHeight="38"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="PHONE" styleClass="form-label"/>
                    <TextField fx:id="editPhoneField" prefHeight="38"/>
                </VBox>
            </HBox>

            <HBox spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="COUNTRY" styleClass="form-label"/>
                    <TextField fx:id="editCountryField" prefHeight="38"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="HEADLINE" styleClass="form-label"/>
                    <TextField fx:id="editHeadlineField" prefHeight="38"/>
                </VBox>
            </HBox>

            <VBox spacing="3">
                <Label text="BIO" styleClass="form-label"/>
                <TextArea fx:id="editBioField" prefHeight="60" wrapText="true"/>
            </VBox>

            <HBox spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="INTERESTS (comma-separated)" styleClass="form-label"/>
                    <TextField fx:id="editInterestsField" prefHeight="38"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="LEARNING GOALS" styleClass="form-label"/>
                    <TextField fx:id="editGoalsField" prefHeight="38"/>
                </VBox>
            </HBox>

            <HBox spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="SKILL LEVEL" styleClass="form-label"/>
                    <ComboBox fx:id="editSkillCombo" prefHeight="38" prefWidth="200"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="PREFERRED LANGUAGE" styleClass="form-label"/>
                    <ComboBox fx:id="editLangCombo" prefHeight="38" prefWidth="200"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="DAILY GOAL (min)" styleClass="form-label"/>
                    <ComboBox fx:id="editGoalMinCombo" prefHeight="38" prefWidth="150"/>
                </VBox>
            </HBox>

            <!-- Actions -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Label fx:id="editError" styleClass="error-label" managed="false" visible="false"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Cancel" styleClass="btn-outline" onAction="#cancelEdit" prefHeight="38"/>
                <Button fx:id="saveBtn" text="💾  Save Changes" styleClass="btn-gradient" onAction="#saveProfile" prefHeight="38"/>
                <ProgressIndicator fx:id="saveLoading" prefWidth="20" prefHeight="20" managed="false" visible="false"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
