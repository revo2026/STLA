<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="560" minWidth="360" prefHeight="800" prefWidth="1200" style="-fx-background-color: #0a0f1e;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="com.stla.ui.auth.LoginController">

    <!-- Decorative glow blobs -->
    <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mouseTransparent="true" style="-fx-background-color: radial-gradient(center 12% 10%, radius 55%, rgba(45,212,191,0.20), transparent 68%);" />
    <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mouseTransparent="true" style="-fx-background-color: radial-gradient(center 88% 90%, radius 50%, rgba(99,102,241,0.18), transparent 70%);" />

    <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;" vbarPolicy="AS_NEEDED">
        <VBox alignment="TOP_CENTER" fillWidth="true" style="-fx-padding: 28 24 36 24; -fx-background-color: transparent;">

            <HBox fx:id="authSplit" alignment="CENTER" maxWidth="1280" spacing="40" style="-fx-alignment: center;" VBox.vgrow="ALWAYS">

                <!-- Branding panel -->
                <VBox fx:id="brandPanel" alignment="CENTER_LEFT" maxWidth="480" minWidth="260" prefWidth="420" spacing="18" style="-fx-padding: 24 16 24 8;" HBox.hgrow="SOMETIMES">

                    <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 999; -fx-padding: 8 16; -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 999; -fx-border-width: 1;">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8899b4; -fx-letter-spacing: 1.2;" text="✦ STLA LEARNING PLATFORM" />
                    </HBox>

                    <VBox spacing="2" style="-fx-padding: 8 0 0 0;">
                        <Label style="-fx-font-family: 'Georgia', 'Times New Roman', serif; -fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;" text="Learn." />
                        <Label style="-fx-font-family: 'Georgia', 'Times New Roman', serif; -fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: #2dd4bf;" text="Teach." />
                        <Label style="-fx-font-family: 'Georgia', 'Times New Roman', serif; -fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: rgba(240,246,255,0.45);" text="Excel." />
                    </VBox>

                    <Label maxWidth="400" style="-fx-font-size: 14px; -fx-text-fill: #8899b4; -fx-line-spacing: 4;" text="Courses, quizzes, certificates and instructor tools — in one elegant desktop app." wrapText="true" />

                    <Region maxHeight="2" maxWidth="120" minHeight="2" prefHeight="4" style="-fx-background-color: linear-gradient(to right, #2dd4bf, #0ea5e9); -fx-background-radius: 2;" />

                    <HBox alignment="CENTER_LEFT" spacing="10" />
                </VBox>

                <!-- Login card -->
                <StackPane alignment="CENTER" minWidth="300" style="-fx-padding: 8 0;" HBox.hgrow="ALWAYS">
                    <VBox fx:id="loginCard" alignment="CENTER_LEFT" maxWidth="480" minWidth="300" prefWidth="460" spacing="14" style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 24; -fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 24; -fx-border-width: 1; -fx-padding: 36 32 28 32; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.45), 48, 0.08, 0, 20);">

                        <VBox spacing="6">
                            <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f0f6ff;" text="Welcome back" />
                            <Label style="-fx-font-size: 14px; -fx-text-fill: #8899b4;" text="Sign in to continue to your dashboard" wrapText="true" />
                        </VBox>

                        <Label style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 2; -fx-padding: 4 0 0 0;" text="Sign in as" />

                        <HBox style="-fx-background-color: rgba(255,255,255,0.04); -fx-background-radius: 16; -fx-padding: 6; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 16; -fx-border-width: 1;">
                            <FlowPane fx:id="roleSelector" hgap="6" prefWrapLength="400" style="-fx-alignment: center-left;" vgap="6">
                                <Button fx:id="roleStudentBtn" maxWidth="1.7976931348623157E308" minWidth="100" onAction="#handleSelectStudent" prefHeight="40" style="-fx-background-radius: 12; -fx-border-radius: 12;" styleClass="role-btn, role-btn-active" text="Student" />
                                <Button fx:id="roleInstructorBtn" maxWidth="1.7976931348623157E308" minWidth="100" onAction="#handleSelectInstructor" prefHeight="40" style="-fx-background-radius: 12; -fx-border-radius: 12;" styleClass="role-btn" text="Instructor" />
                                <Button fx:id="roleAdminBtn" maxWidth="1.7976931348623157E308" minWidth="100" onAction="#handleSelectAdmin" prefHeight="40" style="-fx-background-radius: 12; -fx-border-radius: 12;" styleClass="role-btn" text="Admin" />
                            </FlowPane>
                        </HBox>

                        <Label style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 2;" text="Email" />
                        <TextField fx:id="emailField" maxWidth="1.7976931348623157E308" prefHeight="46" promptText="Enter your email" style="-fx-background-color: rgba(255,255,255,0.03); -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #f0f6ff; -fx-prompt-text-fill: #4a6080; -fx-padding: 12 16; -fx-font-size: 14px;" />

                        <Label style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 2;" text="Password" />
                        <PasswordField fx:id="passwordField" maxWidth="1.7976931348623157E308" prefHeight="46" promptText="Enter your password" style="-fx-background-color: rgba(255,255,255,0.03); -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 12; -fx-background-radius: 12; -fx-text-fill: #f0f6ff; -fx-prompt-text-fill: #4a6080; -fx-padding: 12 16; -fx-font-size: 14px;" />

                        <CheckBox fx:id="rememberMeCheckbox" style="-fx-font-size: 13px; -fx-text-fill: #8899b4;" text="Remember me" />

                        <Label fx:id="errorLabel" managed="false" maxWidth="1.7976931348623157E308" style="-fx-font-size: 12px; -fx-text-fill: #f87171; -fx-background-color: rgba(248,113,113,0.12); -fx-background-radius: 10; -fx-padding: 10 14;" text="" visible="false" wrapText="true" />

                        <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" onAction="#handleLogin" prefHeight="48" style="-fx-background-color: linear-gradient(to right, #2dd4bf, #0ea5e9); -fx-text-fill: #0a0f1e; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-border-radius: 12; -fx-cursor: hand; -fx-padding: 12 24; -fx-effect: dropshadow(gaussian, rgba(45,212,191,0.35), 16, 0.2, 0, 6);" text="Sign in" />

                        <HBox alignment="CENTER">
                            <ProgressIndicator fx:id="loadingIndicator" managed="false" prefHeight="28" prefWidth="28" style="-fx-progress-color: #2dd4bf;" visible="false" />
                        </HBox>

                        <HBox alignment="CENTER" spacing="12">
                            <Region maxHeight="1" minHeight="1" style="-fx-background-color: rgba(255,255,255,0.10);" HBox.hgrow="ALWAYS" />
                            <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-letter-spacing: 1.5;" text="OR" />
                            <Region maxHeight="1" minHeight="1" style="-fx-background-color: rgba(255,255,255,0.10);" HBox.hgrow="ALWAYS" />
                        </HBox>

                        <HBox alignment="CENTER" spacing="6">
                            <Label style="-fx-font-size: 13px; -fx-text-fill: #8899b4;" text="Don't have an account?" />
                            <Button fx:id="registerLink" onAction="#handleGoToRegister" style="-fx-text-fill: #2dd4bf; -fx-underline: true; -fx-background-color: transparent;" styleClass="link-btn" text="Create account" />
                        </HBox>

                        <HBox alignment="CENTER" spacing="4" style="-fx-padding: 8 0 0 0;" />
                    </VBox>
                </StackPane>
            </HBox>
        </VBox>
    </ScrollPane>
</StackPane>
