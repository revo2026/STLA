                                    </VBox>
                                    <VBox fx:id="idBackCard" alignment="CENTER" onMouseClicked="#handleIdBackUpload" spacing="6" style="-fx-background-color: rgba(255,255,255,0.04); -fx-background-radius: 14; -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 14; -fx-border-width: 1; -fx-padding: 12; -fx-cursor: hand;" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-size: 28px;" text="🪪" />
