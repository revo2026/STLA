                                <Label fx:id="docsErr" managed="false" style="-fx-font-size: 12px; -fx-text-fill: #f87171; -fx-background-color: rgba(248,113,113,0.12); -fx-background-radius: 8; -fx-padding: 6 10;" visible="false" />

                                <Region prefHeight="4" />
