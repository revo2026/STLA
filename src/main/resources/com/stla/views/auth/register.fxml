                            </VBox>

                            <Label fx:id="globalError" managed="false" maxWidth="1.7976931348623157E308" style="-fx-font-size: 12px; -fx-text-fill: #f87171; -fx-background-color: rgba(248,113,113,0.12); -fx-background-radius: 10; -fx-padding: 10 14;" visible="false" wrapText="true" />

                            <HBox alignment="CENTER" spacing="12">
                                <Region maxHeight="1" minHeight="1" style="-fx-background-color: rgba(255,255,255,0.10);" HBox.hgrow="ALWAYS" />
