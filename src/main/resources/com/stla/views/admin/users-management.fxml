<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.stla.ui.admin.UsersManagementController"
      spacing="16" style="-fx-padding: 28 32; -fx-background-color: #0a0f1e;">
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="👥 Users Management" styleClass="heading-1" HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel" text="" styleClass="text-secondary"/>
    </HBox>
    <HBox spacing="12">
        <TextField fx:id="searchField" promptText="🔍 Search users..." styleClass="search-field" prefWidth="300"/>
        <ComboBox fx:id="roleFilter" prefWidth="150"/>
    </HBox>
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <VBox fx:id="usersContainer" spacing="4"/>
    </ScrollPane>
</VBox>
