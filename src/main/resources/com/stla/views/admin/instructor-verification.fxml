<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.stla.ui.admin.InstructorVerificationController"
      spacing="16" style="-fx-padding: 28 32; -fx-background-color: #0a0f1e;">
    <Label text="✅ Instructor Verification Requests" styleClass="heading-1"/>
    <Label fx:id="countLabel" text="Loading..." style="-fx-font-size: 13px; -fx-text-fill: #8899b4;"/>
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <VBox fx:id="requestsContainer" spacing="12"/>
    </ScrollPane>
</VBox>
